{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [".next/**", "out/**", "node_modules/**", "coverage/**", "dist/**"],
  "plugins": ["nextjs", "react", "typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "react/react-in-jsx-scope": "off"
  },
  "env": {
    "browser": true,
    "node": true
  }
}
